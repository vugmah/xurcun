# ═══════════════════════════════════════════════════════════════
# Xurcun — Environment Variables
# Copy this file to .env and fill in all values before deployment
# NEVER commit .env to git (it is already in .gitignore)
# ═══════════════════════════════════════════════════════════════

# ═══ REQUIRED ═══════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_ID=xurcun_prod
APP_SECRET=GENERATE_64_CHAR_SECRET_HERE

# ── Database (MySQL 8.0+) ─────────────────────────────────────
# Railway auto-generates this after MySQL provision
DATABASE_URL=mysql://user:password@host:port/database

# ── Admin Authentication ───────────────────────────────────────
ADMIN_SECRET_KEY=GENERATE_64_CHAR_KEY_HERE

# ── Node Environment ───────────────────────────────────────────
NODE_ENV=production

# ── Server Port ────────────────────────────────────────────────
PORT=3000

# ═══ FRONTEND TRACKING (optional, set via admin panel) ═════════

VITE_SITE_URL=https://xurcun.az

# Google Tag Manager Container ID
VITE_GTM_CONTAINER_ID=

# Google Analytics 4 Measurement ID
VITE_GA4_MEASUREMENT_ID=

# Google Ads Conversion ID
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_CONVERSION_ID=

# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=

# Google Search Verification
VITE_GOOGLE_SITE_VERIFICATION=

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=

# WhatsApp number
VITE_SEABREEZE_WHATSAPP=

# ═══ OPTIONAL: BACKEND INTEGRATIONS ═══════════════════════════

# ── Google Ads API ────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Meta Conversions API ──────────────────────────────────────
META_CAPI_ACCESS_TOKEN=
META_CAPI_PIXEL_ID=

# ── SMTP for contact form ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Supabase Storage (permanent image/video uploads) ──
# Without these, uploads fall back to local disk (wiped on every Railway redeploy).
# 1) Create a project at supabase.com  2) Storage → create a PUBLIC bucket named "media"
# 3) Project Settings → API → copy the values below.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=media

# ── AI Auto-Translation (catalog → AZ/RU/EN/TR/AR) ──
# OpenAI API key (platform.openai.com). Leave empty to disable the auto-translate button.
OPENAI_API_KEY=
# Optional: override model (default gpt-4o-mini)
TRANSLATE_MODEL=gpt-4o-mini
# Anthropic (Claude) API key (console.anthropic.com) — alternative to OpenAI.
ANTHROPIC_API_KEY=
# translate_provider: "openai" | "anthropic" | "" (auto-detect by which key exists)
TRANSLATE_PROVIDER=
